<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>MY APP</title>
  <link rel="stylesheet" href="/style.css">
</head>

<body>
  <header class="hero">
    <h1>My Library</h1>
  </header>

  <main>
    <section class="form-section">
      <form action="/books" method="POST">
        <input type="text" placeholder="Book title" name="title" />
        <input type="text" placeholder="Author" name="author" />
        <button type="submit">Add Book</button>
      </form>
    </section>

    <section class="books-section">
      <h2>Books</h2>

      <ul>
        <% for (let i = 0; i < books.length; i++) { %>
          <li>
            <div class="book-info">
              <strong><%= books[i].title %></strong>
              <span>by <%= books[i].author %></span>
            </div>

            <div>
              <button class="update-button" data-id="<%= books[i]._id %>">Update</button>
              <button class="delete-button" data-id="<%= books[i]._id %>">Delete</button>
            </div>
          </li>
        <% } %>
      </ul>
    </section>

    <div id="message"></div>
  </main>

  <script src="/main.js"></script>
</body>
</html>